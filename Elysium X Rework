getgenv().gamesConfig = {  
    {  
        gameName = "Name",  
        placeId = 0000,  
        ConfigScript = [[ loadstring(game:HttpGet(""))() ]]  
    },  
}  

getgenv().gamechecker = true  
getgenv().ScriptName = "Elysium X Rework"  
getgenv().UniversalScript = [[ loadstring(game:HttpGet("https://raw.githubusercontent.com/HS1HYDRAX7/Elysium-X-Rework/refs/heads/main/Loader/Elysium%20X%20Universal"))() ]]  

local CONFIG = {
    ContainerWidth = 540,
    ContainerHeight = 150,
    BarHeight = 10,
    BarPaddingX = 40,
    BarLerpSpeed = 0.35,
    FadeInSpeed = 0.25,
    FadeOutSpeed = 0.25,
    PopupTime = 0.35
}

local TweenService = game:GetService("TweenService")
local RunService = game:GetService("RunService")
local player = game:GetService("Players").LocalPlayer

local screenGui = Instance.new("ScreenGui")
screenGui.Name = "ZenithLoader"
screenGui.ZIndexBehavior = Enum.ZIndexBehavior.Sibling
screenGui.ResetOnSpawn = false

pcall(function()
    screenGui.Parent = game:GetService("CoreGui")
end)
if not screenGui.Parent then
    screenGui.Parent = player:WaitForChild("PlayerGui")
end

local container = Instance.new("Frame")
container.AnchorPoint = Vector2.new(0.5,0.5)
container.Position = UDim2.new(0.5,0,0.5,0)
container.Size = UDim2.new(0,0,0,0)
container.BackgroundColor3 = Color3.fromRGB(10,10,10)
container.BackgroundTransparency = 1
container.Parent = screenGui
Instance.new("UICorner", container).CornerRadius = UDim.new(0,14)

local stroke = Instance.new("UIStroke", container)
stroke.Thickness = 2
stroke.Transparency = 1

local grad = Instance.new("UIGradient", stroke)
grad.Color = ColorSequence.new{
    ColorSequenceKeypoint.new(0, Color3.fromRGB(20,20,60)),
    ColorSequenceKeypoint.new(0.5, Color3.fromRGB(120,0,40)),
    ColorSequenceKeypoint.new(1, Color3.fromRGB(20,20,60))
}

local statusLabel = Instance.new("TextLabel")
statusLabel.Size = UDim2.new(1,-80,0,22)
statusLabel.Position = UDim2.new(0,40,0,35)
statusLabel.BackgroundTransparency = 1
statusLabel.Text = "Checking Game..."
statusLabel.TextColor3 = Color3.fromRGB(255,255,255)
statusLabel.TextSize = 15
statusLabel.Font = Enum.Font.GothamBold
statusLabel.TextTransparency = 1
statusLabel.Parent = container

local percentLabel = Instance.new("TextLabel")
percentLabel.Size = UDim2.new(0,50,0,20)
percentLabel.Position = UDim2.new(1,-70,0,35)
percentLabel.BackgroundTransparency = 1
percentLabel.Text = "0%"
percentLabel.TextColor3 = Color3.fromRGB(255,0,0)
percentLabel.TextSize = 14
percentLabel.Font = Enum.Font.GothamBold
percentLabel.TextTransparency = 1
percentLabel.Parent = container

local barBackground = Instance.new("Frame")
barBackground.Size = UDim2.new(1,-100,0,CONFIG.BarHeight)
barBackground.Position = UDim2.new(0,40,0,80)
barBackground.BackgroundColor3 = Color3.fromRGB(25,25,25)
barBackground.BackgroundTransparency = 1
barBackground.Parent = container
Instance.new("UICorner", barBackground).CornerRadius = UDim.new(0,4)

local barFill = Instance.new("Frame")
barFill.Size = UDim2.new(0,0,1,0)
barFill.BackgroundTransparency = 1
barFill.Parent = barBackground
Instance.new("UICorner", barFill).CornerRadius = UDim.new(0,4)

local barGrad = Instance.new("UIGradient", barFill)
barGrad.Color = ColorSequence.new{
    ColorSequenceKeypoint.new(0, Color3.fromRGB(255,0,0)),
    ColorSequenceKeypoint.new(1, Color3.fromRGB(255,80,80))
}

local spinner = Instance.new("ImageLabel")
spinner.Size = UDim2.new(0,22,0,22)
spinner.Position = UDim2.new(1,10,0.5,-11)
spinner.BackgroundTransparency = 1
spinner.Image = "rbxassetid://116535712789945"
spinner.ImageColor3 = Color3.fromRGB(255,0,0)
spinner.Parent = barBackground

local creditFrame = Instance.new("Frame")
creditFrame.Size = UDim2.new(1,-80,0,20)
creditFrame.Position = UDim2.new(0,40,1,-25)
creditFrame.BackgroundTransparency = 1
creditFrame.Parent = container

local creditText = "Made By Zenith Studios"
local letters = {}

for i = 1, #creditText do
    local char = creditText:sub(i,i)
    local lbl = Instance.new("TextLabel")
    lbl.Size = UDim2.new(0,10,1,0)
    lbl.Position = UDim2.new(0,(i-1)*10,0,0)
    lbl.BackgroundTransparency = 1
    lbl.Text = char
    lbl.TextColor3 = Color3.fromRGB(255,0,0)
    lbl.TextSize = 13
    lbl.Font = Enum.Font.GothamBold
    lbl.TextTransparency = 1
    lbl.Parent = creditFrame
    table.insert(letters,lbl)
end

local function animateCredits()
    for i, lbl in ipairs(letters) do
        lbl.Position = lbl.Position + UDim2.new(0,0,1,0)
        TweenService:Create(lbl, TweenInfo.new(0.4, Enum.EasingStyle.Back), {
            TextTransparency = 0,
            Position = lbl.Position - UDim2.new(0,0,1,0)
        }):Play()
        task.wait(0.04)
    end
end

local selectedScript = nil
local gameName = "Unknown"

if getgenv().gamechecker then
    for _, g in pairs(getgenv().gamesConfig) do
        if game.PlaceId == g.placeId then
            selectedScript = g.ConfigScript
            gameName = g.gameName
            break
        end
    end
end

if not selectedScript then
    selectedScript = getgenv().UniversalScript
end

local function popupIn()
    TweenService:Create(container, TweenInfo.new(CONFIG.PopupTime, Enum.EasingStyle.Back), {
        Size = UDim2.new(0,CONFIG.ContainerWidth,0,CONFIG.ContainerHeight),
        BackgroundTransparency = 0
    }):Play()
end

local function popupOut()
    TweenService:Create(container, TweenInfo.new(CONFIG.PopupTime, Enum.EasingStyle.Back, Enum.EasingDirection.In), {
        Size = UDim2.new(0,0,0,0),
        BackgroundTransparency = 1
    }):Play()
end

local function fadeIn()
    local info = TweenInfo.new(CONFIG.FadeInSpeed)
    TweenService:Create(stroke, info, {Transparency = 0}):Play()
    TweenService:Create(statusLabel, info, {TextTransparency = 0}):Play()
    TweenService:Create(percentLabel, info, {TextTransparency = 0}):Play()
    TweenService:Create(barBackground, info, {BackgroundTransparency = 0}):Play()
    TweenService:Create(barFill, info, {BackgroundTransparency = 0}):Play()
end

local function fadeOut()
    local info = TweenInfo.new(CONFIG.FadeOutSpeed)
    TweenService:Create(stroke, info, {Transparency = 1}):Play()
    TweenService:Create(statusLabel, info, {TextTransparency = 1}):Play()
    TweenService:Create(percentLabel, info, {TextTransparency = 1}):Play()
    TweenService:Create(barBackground, info, {BackgroundTransparency = 1}):Play()
    TweenService:Create(barFill, info, {BackgroundTransparency = 1}):Play()
end

local function updateLoader(status, progress)
    statusLabel.Text = status
    percentLabel.Text = math.floor(progress).."%"
    TweenService:Create(barFill, TweenInfo.new(CONFIG.BarLerpSpeed), {
        Size = UDim2.new(progress/100,0,1,0)
    }):Play()
end

RunService.RenderStepped:Connect(function(dt)
    grad.Rotation += dt*90
    spinner.Rotation += dt*180
end)

task.spawn(function()
    popupIn()
    task.wait(CONFIG.PopupTime)
    fadeIn()
    animateCredits()

    task.wait(0.5)
    updateLoader("Detected: "..gameName, 30)
    task.wait(0.8)
    updateLoader("Loading "..getgenv().ScriptName, 70)
    task.wait(0.8)
    updateLoader("Finalizing Execution", 100)
    task.wait(0.5)

    task.spawn(function()
        pcall(function()
            loadstring(selectedScript)()
        end)
    end)

    fadeOut()
    task.wait(CONFIG.FadeOutSpeed)
    popupOut()
    task.wait(CONFIG.PopupTime)

    screenGui:Destroy()
end)
