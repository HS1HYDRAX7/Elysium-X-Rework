Instance.new("UICorner", container).CornerRadius = UDim.new(0,14)

local stroke = Instance.new("UIStroke", container)
stroke.Thickness = 2

local grad = Instance.new("UIGradient", stroke)
grad.Color = ColorSequence.new{
    ColorSequenceKeypoint.new(0, Color3.fromRGB(80,0,0)),
    ColorSequenceKeypoint.new(0.5, Color3.fromRGB(150,0,40)),
    ColorSequenceKeypoint.new(1, Color3.fromRGB(80,0,0))
}

local function createAnimatedText(parent, text, color)
    local letters = {}
    for i = 1, #text do
        local char = text:sub(i,i)
        local lbl = Instance.new("TextLabel")
        lbl.Size = UDim2.new(0,10,1,0)
        lbl.Position = UDim2.new(0,(i-1)*10,0,0)
        lbl.BackgroundTransparency = 1
        lbl.Text = char
        lbl.TextColor3 = color
        lbl.TextSize = 15
        lbl.Font = Enum.Font.GothamBold
        lbl.TextTransparency = 1
        lbl.Parent = parent
        table.insert(letters,lbl)
    end
    return letters
end

local function animateLetters(tbl)
    for i,lbl in ipairs(tbl) do
        lbl.Position = lbl.Position + UDim2.new(0,0,1,0)
        TweenService:Create(lbl, TweenInfo.new(0.35,Enum.EasingStyle.Back),{
            TextTransparency = 0,
            Position = lbl.Position - UDim2.new(0,0,1,0)
        }):Play()
        task.wait(0.03)
    end
end

