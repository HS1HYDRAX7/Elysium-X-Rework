local function updateLoader(progress)
    percentLabel.Text = math.floor(progress).."%"
    TweenService:Create(barFill, TweenInfo.new(CONFIG.BarLerpSpeed), {
        Size = UDim2.new(progress/100,0,1,0)
    }):Play()
end

RunService.RenderStepped:Connect(function(dt)
    grad.Rotation += dt*120
    spinner.Rotation += dt*180
end)

local selectedScript = nil
local gameName = "Unknown"

if getgenv().gamechecker then
    for _, g in pairs(getgenv().gamesConfig) do
        if game.PlaceId == g.placeId then
            selectedScript = g.ConfigScript
            gameName = g.gameName
            break
        end
    end
end

if not selectedScript then
    selectedScript = getgenv().UniversalScript
end

local function popupIn()
    TweenService:Create(container, TweenInfo.new(CONFIG.PopupTime, Enum.EasingStyle.Back), {
        Size = UDim2.new(0,CONFIG.ContainerWidth,0,CONFIG.ContainerHeight)
    }):Play()
end

local function popupOut()
    TweenService:Create(container, TweenInfo.new(CONFIG.PopupTime, Enum.EasingStyle.Back, Enum.EasingDirection.In), {
        Size = UDim2.new(0,0,0,0)
    }):Play()
end

task.spawn(function()
    popupIn()
    task.wait(CONFIG.PopupTime)

    animateLetters(statusLetters)
    animateLetters(creditLetters)

    task.wait(0.6)
    updateLoader(30)

    task.wait(0.8)
    updateLoader(70)

    task.wait(0.8)

    statusFrame.Visible = false
    executingFrame.Visible = true
    animateLetters(executingLetters)

    updateLoader(100)

task.delay(4, function()
    finishSound:Play()
end)

    task.wait(0.5)

    task.spawn(function()
        pcall(function()
            loadstring(selectedScript)()
        end)
    end)

    popupOut()
    task.wait(CONFIG.PopupTime)

    screenGui:Destroy()
end)
