    ColorSequenceKeypoint.new(0.5, Color3.fromRGB(120,0,40)),
    ColorSequenceKeypoint.new(1, Color3.fromRGB(20,20,60))
}

local function createAnimatedText(parent, text, yPos)
    local frame = Instance.new("Frame")
    frame.Size = UDim2.new(1,-80,0,22)
    frame.Position = UDim2.new(0,40,0,yPos)
    frame.BackgroundTransparency = 1
    frame.Parent = parent

    local letters = {}

    for i = 1, #text do
        local char = text:sub(i,i)
        local lbl = Instance.new("TextLabel")
        lbl.Size = UDim2.new(0,10,1,0)
        lbl.Position = UDim2.new(0,(i-1)*10,0,0)
        lbl.BackgroundTransparency = 1
        lbl.Text = char
        lbl.TextColor3 = Color3.fromRGB(255,255,255)
        lbl.TextSize = 15
        lbl.Font = Enum.Font.GothamBold
        lbl.TextTransparency = 1
        lbl.Parent = frame
        table.insert(letters,lbl)
    end

    local function animate(newText)
        for i, lbl in ipairs(letters) do
            local char = newText:sub(i,i) or ""
            lbl.Text = char
            lbl.Position = lbl.Position + UDim2.new(0,0,1,0)
            TweenService:Create(lbl, TweenInfo.new(0.35, Enum.EasingStyle.Back), {
                TextTransparency = 0,
                Position = lbl.Position - UDim2.new(0,0,1,0)
            }):Play()
            task.wait(0.02)
        end
    end

    return frame, animate
end

local statusFrame, animateStatus = createAnimatedText(container,"Checking Game...",35)

