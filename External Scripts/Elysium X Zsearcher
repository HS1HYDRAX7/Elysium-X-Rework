local function fetch(q)
    local url = "https://scriptblox.com/api/script/search?q="..HttpService:UrlEncode(q)
    local ok,res = pcall(function()
        return HttpService:JSONDecode(game:HttpGet(url))
    end)
    if ok and res and res.result then
        return res.result.scripts or {}
    end
    return {}
end

local function creditAnim(label,text)
    label.Text = ""
    for i=1,#text do
        label.Text = label.Text..text:sub(i,i)
        label.TextTransparency = 1
        TweenService:Create(label,TweenInfo.new(0.3,Enum.EasingStyle.Back),{
            TextTransparency = 0
        }):Play()
        task.wait(0.02)
    end
end

local function loadingCard(card)
    local spinner = Instance.new("ImageLabel")
    spinner.Size = UDim2.new(0,20,0,20)
    spinner.Position = UDim2.new(0.5,0,0.5,0)
    spinner.AnchorPoint = Vector2.new(0.5,0.5)
    spinner.BackgroundTransparency = 1
    spinner.Image = "rbxassetid://116535712789945"
    spinner.Parent = card

    local conn
    conn = RunService.RenderStepped:Connect(function(dt)
        spinner.Rotation += dt*180
        if not spinner.Parent then
            conn:Disconnect()
        end
    end)

    task.wait(0.4)
    spinner:Destroy()
end

local function card(data)
    local c = Instance.new("Frame")
    c.BackgroundColor3 = config.keyColor
    c.Parent = Results
    Instance.new("UICorner",c)

    loadingCard(c)

    local title = Instance.new("TextLabel")
    title.Size = UDim2.new(1,-10,0,20)
    title.Position = UDim2.new(0,6,0,10)
    title.BackgroundTransparency = 1
    title.TextColor3 = config.textColor
    title.Font = Enum.Font.GothamBold
    title.TextSize = 13
    title.Text = ""
    title.Parent = c

    task.spawn(function()
        creditAnim(title, data.title or "Unknown")
    end)

    local views = Instance.new("TextLabel")
    views.Size = UDim2.new(1,-10,0,18)
    views.Position = UDim2.new(0,6,0,35)
    views.BackgroundTransparency = 1
    views.TextColor3 = Color3.fromRGB(255,0,0)
    views.Font = Enum.Font.GothamBold
    views.TextSize = 11
    views.Text = tostring(data.views or 0).." views"
    views.Parent = c

    local exec = Instance.new("TextButton")
    exec.Size = UDim2.new(1,-10,0,24)
    exec.Position = UDim2.new(0,6,1,-30)
    exec.BackgroundColor3 = Color3.fromRGB(255,0,0)
    exec.Text = "Execute"
    exec.TextColor3 = Color3.new(0,0,0)
    exec.Font = Enum.Font.GothamBold
    exec.TextSize = 12
    exec.Parent = c
    Instance.new("UICorner",exec)

    exec.MouseButton1Click:Connect(function()
        if data.script then
            loadstring(data.script)()
        end
    end)

    c.Size = UDim2.new(0,0,0,0)
    TweenService:Create(c,TweenInfo.new(0.3,Enum.EasingStyle.Back),{
        Size = UDim2.new(1,0,1,0)
    }):Play()
end

local function render(q)
    for _,v in ipairs(Results:GetChildren()) do
        if v:IsA("Frame") then
            v:Destroy()
        end
    end

    local list = fetch(q)

    for i,v in ipairs(list) do
        task.delay(i*0.05,function()
            card(v)
        end)
    end

    task.wait()
    Results.CanvasSize = UDim2.new(0,0,0,Grid.AbsoluteContentSize.Y+10)
end

Box.FocusLost:Connect(function(e)
    if e then
        render(Box.Text)
    end
end)

Results:GetPropertyChangedSignal("CanvasPosition"):Connect(function()
    local percent = Results.CanvasPosition.Y / (Results.CanvasSize.Y.Offset)
    Slider.Size = UDim2.new(0,4,math.clamp(1-percent,0.1,1),0)
end)
