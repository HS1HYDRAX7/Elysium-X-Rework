KeyboardFrame.Parent = MainFrame

local keyboardKeys = {
    {{"W",3}},
    {{"A",1},{"S",3},{"Space",4}},
    {{"D",3}}
}

local controllerKeys = {
    {{"Y",1},{"X",1},{"B",1},{"A",1}},
    {{"Left",1},{"Down",1},{"Right",1}},
    {{"LAnalog",2},{"RAnalog",2}}
}

local function createKey(keyData)
    local keyName = keyData[1]
    local keyWidth = keyData[2] or 1
    local key = Instance.new("TextButton")
    key.Name = "Key_"..keyName
    key.Size = UDim2.new(0,42*keyWidth+(3*(keyWidth-1)),0,38)
    key.BackgroundColor3 = config.keyColor
    key.TextColor3 = config.textColor
    key.Font = Enum.Font.GothamBold
    key.TextSize = 14
    key.BorderSizePixel = 0
    key.AutoButtonColor = false
    key.Parent = KeyboardFrame
    local corner = Instance.new("UICorner")
    corner.CornerRadius = UDim.new(0,8)
    corner.Parent = key
    local stroke = Instance.new("UIStroke")
    stroke.Color = accentColor
    stroke.Thickness = 1
    stroke.Transparency = 0.6
    stroke.Parent = key
    keyButtons[keyName] = key
    key.MouseEnter:Connect(function()
        TweenService:Create(key, TweenInfo.new(0.15), {BackgroundColor3 = accentColor}):Play()
    end)
    key.MouseLeave:Connect(function()
        TweenService:Create(key, TweenInfo.new(0.15), {BackgroundColor3 = config.keyColor}):Play()
    end)
    key.MouseButton1Down:Connect(function()
        TweenService:Create(key, TweenInfo.new(0.05), {Size = key.Size - UDim2.new(0,2,0,2)}):Play()
        pcall(function() keypress(Enum.KeyCode[keyName]) end)
    end)
    key.MouseButton1Up:Connect(function()
        TweenService:Create(key, TweenInfo.new(0.05), {Size = UDim2.new(0,42*keyWidth+(3*(keyWidth-1)),0,38)}):Play()
        pcall(function() keyrelease(Enum.KeyCode[keyName]) end)
    end)
end

function updateKeyboard()
    for _, key in pairs(keyButtons) do
        key:Destroy()
    end
    keyButtons = {}
    local keysToUse = usingController and controllerKeys or keyboardKeys
    local yPos = 4
    for _, row in ipairs(keysToUse) do
        local xPos = 4
        for _, keyData in ipairs(row) do
            local key = createKey(keyData)
            key.Position = UDim2.new(0,xPos,0,yPos)
            local width = keyData[2] or 1
            xPos = xPos + (42*width+(3*(width-1))) + 6
        end
        yPos = yPos + 44
    end
end

updateKeyboard()

