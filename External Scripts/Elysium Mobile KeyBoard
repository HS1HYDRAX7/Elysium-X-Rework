local function updateAccent(newColor)  
    accentColor = newColor  
    TweenService:Create(MainStroke, TweenInfo.new(0.5), {Color = accentColor}):Play()  
    TweenService:Create(TitleLabel, TweenInfo.new(0.5), {TextColor3 = accentColor}):Play()  
    UIGradient.Color = ColorSequence.new{  
        ColorSequenceKeypoint.new(0, accentColor),  
        ColorSequenceKeypoint.new(1, config.bgColor)  
    }  
    updateKeyboard()  
end  

task.spawn(function()  
    while true do  
        task.wait(2)  
        currentColorIndex += 1  
        if currentColorIndex > #colorThemes[currentTheme] then  
            currentColorIndex = 1  
            currentTheme = currentTheme == 1 and 2 or 1  
        end  
        updateAccent(colorThemes[currentTheme][currentColorIndex])  
    end  
end)  

local function createControlButton(text, position, callback)  
    local btn = Instance.new("TextButton")  
    btn.Size = UDim2.new(0, 32, 0, 32)  
    btn.Position = position  
    btn.AnchorPoint = Vector2.new(1, 0.5)  
    btn.BackgroundColor3 = config.keyColor  
    btn.Text = text  
    btn.TextColor3 = config.textColor  
    btn.Font = Enum.Font.GothamBold  
    btn.TextSize = 18  
    btn.BorderSizePixel = 0  
    btn.AutoButtonColor = false  
    btn.Parent = TitleBar  
      
    local corner = Instance.new("UICorner")  
    corner.CornerRadius = UDim.new(0, 8)  
    corner.Parent = btn  
      
    btn.MouseEnter:Connect(function()  
        TweenService:Create(btn, TweenInfo.new(0.2), {  
            BackgroundColor3 = accentColor,  
            Size = UDim2.new(0, 36, 0, 36)  
        }):Play()  
    end)  
      
    btn.MouseLeave:Connect(function()  
        TweenService:Create(btn, TweenInfo.new(0.2), {  
            BackgroundColor3 = config.keyColor,  
            Size = UDim2.new(0, 32, 0, 32)  
        }):Play()  
    end)  
      
    btn.MouseButton1Click:Connect(callback)  
end  

