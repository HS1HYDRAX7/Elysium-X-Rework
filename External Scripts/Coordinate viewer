local function createCoordLabel(text)
	local Label = Instance.new("Frame")
	Label.Size = UDim2.new(1,0,0,34)
	Label.BackgroundColor3 = Color3.fromRGB(32,32,40)
	Label.BorderSizePixel = 0
	Label.Parent = Container
	
	local corner = Instance.new("UICorner", Label)
	corner.CornerRadius = UDim.new(0,14)
	
	local stroke = Instance.new("UIStroke", Label)
	stroke.Color = Color3.fromRGB(70,70,85)
	stroke.Transparency = 0.4
	stroke.Thickness = 1
	
	local gradient = Instance.new("UIGradient", Label)
	gradient.Color = ColorSequence.new{
		ColorSequenceKeypoint.new(0, Color3.fromRGB(40,40,55)),
		ColorSequenceKeypoint.new(1, Color3.fromRGB(28,28,38))
	}
	gradient.Rotation = 90
	
	local Text = Instance.new("TextLabel")
	Text.Size = UDim2.new(1,-15,1,0)
	Text.Position = UDim2.new(0,12,0,0)
	Text.BackgroundTransparency = 1
	Text.Text = text
	Text.Font = Enum.Font.Gotham
	Text.TextSize = 14
	Text.TextColor3 = Color3.fromRGB(210,210,220)
	Text.TextXAlignment = Enum.TextXAlignment.Left
	Text.Parent = Label
	
	return Text
end

local XLabel = createCoordLabel("X: 0")
local YLabel = createCoordLabel("Y: 0")
local ZLabel = createCoordLabel("Z: 0")

local function animateLabel(label)
	local tween1 = TweenService:Create(label, TweenInfo.new(0.12), {TextColor3 = Color3.fromRGB(0,170,255)})
	local tween2 = TweenService:Create(label, TweenInfo.new(0.12), {TextColor3 = Color3.fromRGB(210,210,220)})
	tween1:Play()
	tween1.Completed:Wait()
	tween2:Play()
end

local lastPosition = Vector3.new()

RunService.RenderStepped:Connect(function()
	if not humanoidRootPart.Parent then
		character = player.Character or player.CharacterAdded:Wait()
		humanoidRootPart = character:WaitForChild("HumanoidRootPart")
	end
	
	local pos = humanoidRootPart.Position
	
	local x = math.floor(pos.X)
	local y = math.floor(pos.Y)
	local z = math.floor(pos.Z)
	
	if lastPosition.X ~= x then
		XLabel.Text = "X: "..x
		animateLabel(XLabel)
	end
	
	if lastPosition.Y ~= y then
		YLabel.Text = "Y: "..y
		animateLabel(YLabel)
	end
	
	if lastPosition.Z ~= z then
		ZLabel.Text = "Z: "..z
		animateLabel(ZLabel)
	end
	
	lastPosition = Vector3.new(x,y,z)
end)

