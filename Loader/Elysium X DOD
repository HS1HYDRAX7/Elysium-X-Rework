                    end)

                    repeat task.wait() until not workspace.GameAssets.Teams.Killer:FindFirstChild(chrn) or _G.AutoBlockUnhook == true
                    conn:Disconnect()
                end

                for _, v in next, workspace.GameAssets.Teams.Killer:GetChildren() do
                    task.spawn(HookOnto, v)
                end

                workspace.GameAssets.Teams.Killer.ChildAdded:Connect(function(v)
                    task.spawn(HookOnto, v)
                end)

