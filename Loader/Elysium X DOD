        local function getCharacter()
            for _,v in ipairs(workspace:GetDescendants()) do
                if v:IsA("Model") and v.Name == player.Name then
                    return v
                end
            end
        end

        local function removeSelfESP()
            local char = getCharacter()
            if not char then return end

            local h = char:FindFirstChild("ESP_HIGHLIGHT")
            if h then h:Destroy() end
        end

        if state then

            removeSelfESP()

            if _G.ignoreLoop then
                _G.ignoreLoop:Disconnect()
            end

            _G.ignoreLoop = game:GetService("RunService").RenderStepped:Connect(function()
                if not _G.ignoreSelf then return end
                removeSelfESP()
            end)

        else

            _G.ignoreSelf = false

            if _G.ignoreLoop then
                _G.ignoreLoop:Disconnect()
                _G.ignoreLoop = nil
            end

        end

    end
})

