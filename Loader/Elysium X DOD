SkillsSelectorTab:Button({
    Title = "Choose Ability",
    Desc = "",
    Locked = false,
    Callback = function()

        local player = game:GetService("Players").LocalPlayer

        local function getCharacter()
            for _,v in ipairs(workspace:GetDescendants()) do
                if v:IsA("Model") and v.Name == player.Name then
                    return v
                end
            end
        end

        local char = getCharacter()
        if not char then return end

        local ability1 = char:GetAttribute("Ability1")
        local ability2 = char:GetAttribute("Ability2")

        local abilities = {}

        if ability1 and ability1 ~= "None" then
            table.insert(abilities, tostring(ability1))
        end

        if ability2 and ability2 ~= "None" then
            table.insert(abilities, tostring(ability2))
        end

        if #abilities == 0 then return end

        if TestRequire() ~= true then
            ErrorRequire()
            return
        end

        game:GetService("ReplicatedStorage")
            :WaitForChild("Events")
            :WaitForChild("RemoteEvents")
            :WaitForChild("AbilitySelection")
            :FireServer(abilities)

        for _,ability in ipairs(abilities) do
            AbilityModule["CreateAbility"](ReturnAbilityData(ability))
        end

    end
})

