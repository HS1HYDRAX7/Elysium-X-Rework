VisualsTab:Toggle({
    Title = "Ignore (yourself)",
    Desc = "",
    Value = false,
    Callback = function(state)

        local Players = game:GetService("Players")
        local player = Players.LocalPlayer

        _G.ignoreSelf = state

        local function protect(char)
            if not char then return end

            local function remove()
                local h = char:FindFirstChild("ESP_HIGHLIGHT")
                if h then h:Destroy() end
            end

            remove()

            if _G.ignoreAddedConn then
                _G.ignoreAddedConn:Disconnect()
            end

            _G.ignoreAddedConn = char.ChildAdded:Connect(function(child)
                if not _G.ignoreSelf then return end
                if child.Name == "ESP_HIGHLIGHT" then
                    child:Destroy()
                end
            end)
        end

        if state then

            if player.Character then
                protect(player.Character)
            end

            if _G.ignoreCharConn then
                _G.ignoreCharConn:Disconnect()
            end

            _G.ignoreCharConn = player.CharacterAdded:Connect(function(char)
                task.wait(0.1)
                protect(char)
            end)

        else

            _G.ignoreSelf = false

            if _G.ignoreCharConn then
                _G.ignoreCharConn:Disconnect()
                _G.ignoreCharConn = nil
            end

            if _G.ignoreAddedConn then
                _G.ignoreAddedConn:Disconnect()
                _G.ignoreAddedConn = nil
            end

        end

    end
})

