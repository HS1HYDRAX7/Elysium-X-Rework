                local function HookOnto(chr)
                    if not chr:FindFirstChild("HumanoidRootPart") or not chr.HumanoidRootPart:FindFirstChild("Swing") then return end

                    local chrn = chr.Name
                    if not workspace.GameAssets.Teams.Killer:FindFirstChild(chrn) then return end

