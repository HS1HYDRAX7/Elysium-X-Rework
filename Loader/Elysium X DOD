            writefile(file, "[]")
        end

        local data = HttpService:JSONDecode(readfile(file))

        if _G._musicIndex and _G._newMusicName and _G._newMusicID then

            local replaced = false

            for i,v in ipairs(data) do
                if v.Index == _G._musicIndex then
                    data[i] = {
                        Index = _G._musicIndex,
                        Name = _G._newMusicName,
                        ID = _G._newMusicID
                    }
                    replaced = true
