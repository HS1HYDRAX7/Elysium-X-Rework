KillDroidAimbotTab:Toggle({
    Title = "Aimbot",
    Desc = "",
    Value = false,
    Callback = function(state)

        local Players = game:GetService("Players")
        local RunService = game:GetService("RunService")
        local Camera = workspace.CurrentCamera
        local player = Players.LocalPlayer

        _G._aimEnabled = state
        _G._aimStrength = _G._aimStrength or 20

        local function getClosest()
            local closest, dist = nil, math.huge

            for _,v in ipairs(Players:GetPlayers()) do
                if v ~= player and v.Character and v.Character.Parent then

                    local partName = (_G._aimPart == "Torso" and "HumanoidRootPart") or "Head"
                    local part = v.Character:FindFirstChild(partName)

                    if part then
                        local screenPos, visible = Camera:WorldToViewportPoint(part.Position)

                        if visible then
                            local mag = (Vector2.new(screenPos.X, screenPos.Y) - Vector2.new(Camera.ViewportSize.X/2, Camera.ViewportSize.Y/2)).Magnitude

                            if mag < dist then
                                dist = mag
                                closest = part
                            end
                        end
                    end
                end
            end

            return closest
        end

        if state then
            _G._aimConn = RunService.RenderStepped:Connect(function()
                if not _G._aimEnabled then return end

                local target = getClosest()
                if not target then return end

                if _G._wallcheck then
                    local origin = Camera.CFrame.Position
                    local direction = (target.Position - origin)

                    local ray = Ray.new(origin, direction)
                    local hit = workspace:FindPartOnRay(ray, player.Character)

                    if hit and not target:IsDescendantOf(hit.Parent) then
                        return
                    end
                end

                local cf = CFrame.new(Camera.CFrame.Position, target.Position)
                Camera.CFrame = Camera.CFrame:Lerp(cf, _G._aimStrength / 100)
            end)
        else
            if _G._aimConn then
                _G._aimConn:Disconnect()
                _G._aimConn = nil
            end
        end

    end
})

