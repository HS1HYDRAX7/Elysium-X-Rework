        local function split(str)
            local a,b = str:match("(.+) %- (.+)")
            return a,b
        end

        local function stopAll(h)
            for _,t in pairs(h:GetPlayingAnimationTracks()) do
                t:Stop()
            end
        end

        local function apply(animName)
            local char = LocalPlayer.Character
            if not char then return end

            local hum = char:FindFirstChildOfClass("Humanoid")
            if not hum then return end

            local animator = hum:FindFirstChildOfClass("Animator") or Instance.new("Animator", hum)

            stopAll(hum)

            if animName == "Default" then return end

            local category, name = split(animName)
            if not category or not name then return end
            if not animationSets[category] then return end
            if not animationSets[category][name] then return end

            local set = animationSets[category][name]

            local function load(id, priority)
                if id == "0" then return nil end
                local anim = Instance.new("Animation")
                anim.AnimationId = "rbxassetid://"..id
                local track = animator:LoadAnimation(anim)
                track.Priority = priority
                return track
            end

            local idle = load(set.Idle, Enum.AnimationPriority.Core)
            local walk = load(set.Walk, Enum.AnimationPriority.Movement)
            local sprint = load(set.Sprint, Enum.AnimationPriority.Movement)

            if idle then idle:Play() end

            _G.animConn = RunService.RenderStepped:Connect(function()
                local moving = hum.MoveDirection.Magnitude > 0.1
                local speed = hum.WalkSpeed

                if moving and speed > 18 then
                    if sprint and not sprint.IsPlaying then
                        if idle then idle:Stop() end
                        if walk then walk:Stop() end
                        sprint:Play()
                    end
                elseif moving then
                    if walk and not walk.IsPlaying then
                        if idle then idle:Stop() end
                        if sprint then sprint:Stop() end
                        walk:Play()
                    end
                else
                    if idle and not idle.IsPlaying then
                        if walk then walk:Stop() end
                        if sprint then sprint:Stop() end
                        idle:Play()
                    end
                end
            end)
        end

        if state then

            apply(_G.selectedAnim or "Default")

            _G.animCharConn = LocalPlayer.CharacterAdded:Connect(function()
                task.wait(0.5)
                apply(_G.selectedAnim or "Default")
            end)

        else

            if _G.animConn then
                _G.animConn:Disconnect()
                _G.animConn = nil
            end

            if _G.animCharConn then
                _G.animCharConn:Disconnect()
                _G.animCharConn = nil
            end

            local char = LocalPlayer.Character
            if char then
                local hum = char:FindFirstChildOfClass("Humanoid")
                if hum then
                    stopAll(hum)
                end
            end

        end

    end
})

VisualsTab:Toggle({
    Title = "Killer ESP",
    Desc = "",
    Flag = "KillerESP",
    Value = false,
    Callback = function(state)

        local teams = workspace:FindFirstChild("GameAssets")
        teams = teams and teams:FindFirstChild("Teams")
        local killers = teams and teams:FindFirstChild("Killer")
        if not killers then return end

        _G.killerESP = state
        _G.killerColor = _G.killerColor or Color3.fromRGB(128,0,32)

        if state then
            for _,v in ipairs(killers:GetChildren()) do
                if v:IsA("Model") and not v:FindFirstChild("ESP_HIGHLIGHT") then
                    local h = Instance.new("Highlight")
                    h.Name = "ESP_HIGHLIGHT"
                    h.FillColor = _G.killerColor
                    h.OutlineColor = _G.killerColor
                    h.Adornee = v
                    h.Parent = v
                end
            end

            _G.killerAdd = killers.ChildAdded:Connect(function(v)
                if not _G.killerESP then return end
                if v:IsA("Model") then
                    local h = Instance.new("Highlight")
                    h.Name = "ESP_HIGHLIGHT"
                    h.FillColor = _G.killerColor
                    h.OutlineColor = _G.killerColor
                    h.Adornee = v
                    h.Parent = v
                end
            end)

            _G.killerRemove = killers.ChildRemoved:Connect(function(v)
                local h = v:FindFirstChild("ESP_HIGHLIGHT")
                if h then h:Destroy() end
            end)
        else
            if _G.killerAdd then _G.killerAdd:Disconnect() _G.killerAdd = nil end
            if _G.killerRemove then _G.killerRemove:Disconnect() _G.killerRemove = nil end

            for _,v in ipairs(killers:GetChildren()) do
                local h = v:FindFirstChild("ESP_HIGHLIGHT")
