VisualsTab:Toggle({
    Title = "Ignore (yourself)",
    Desc = "",
    Flag = "Ignore",
    Value = false,
    Callback = function(state)

        local player = game:GetService("Players").LocalPlayer
        _G.ignoreSelf = state

        local function handle(folder)
            if not folder then return end
            for _,v in ipairs(folder:GetChildren()) do
                if v:IsA("Model") then
                    local isSelf = (v == player.Character)
                    local h = v:FindFirstChild("ESP_HIGHLIGHT")

                    if isSelf then
                        if state and h then
                            h:Destroy()
                        elseif not state then
                            if not h then
                                local color =
                                    (folder.Name == "Killer" and (_G.killerColor or Color3.fromRGB(128,0,32))) or
                                    (folder.Name == "Survivor" and (_G.survivorColor or Color3.fromRGB(0,100,0))) or
                                    (folder.Name == "Ghost" and (_G.ghostColor or Color3.fromRGB(255,255,255)))

                                local nh = Instance.new("Highlight")
                                nh.Name = "ESP_HIGHLIGHT"
                                nh.FillColor = color
                                nh.OutlineColor = color
                                nh.Adornee = v
                                nh.Parent = v
                            end
                        end
                    end
                end
            end
        end

        local teams = workspace:FindFirstChild("GameAssets")
        teams = teams and teams:FindFirstChild("Teams")

        if teams then
            handle(teams:FindFirstChild("Killer"))
            handle(teams:FindFirstChild("Survivor"))
            handle(teams:FindFirstChild("Ghost"))
        end

    end
})

