                        local unit = ((hrp.Position - chr.HumanoidRootPart.Position) * Vector3.new(1,0,1)).Unit
                        local lookvector = chr.HumanoidRootPart.CFrame.LookVector * Vector3.new(1,0,1)
                        if lookvector:Dot(unit) <= 0.85 then return end

