        else

            if _G.stamConn then
                _G.stamConn:Disconnect()
                _G.stamConn = nil
            end

        end

    end
})

MovementTab:Toggle({
    Title = "Enable Jump (IN-GAME)",
    Desc = "",
    Value = false,
    Callback = function(state)

        local player = game:GetService("Players").LocalPlayer
        local UIS = game:GetService("UserInputService")

        _G.jumpEnabled = state

        local function getCharacter()
            for _,v in ipairs(workspace:GetDescendants()) do
                if v:IsA("Model") and v.Name == player.Name then
                    return v
                end
            end
        end

        local function jump()
            local char = getCharacter()
            if not char then return end

            local hum = char:FindFirstChildOfClass("Humanoid")
            if not hum then return end

            if hum.FloorMaterial ~= Enum.Material.Air then
                hum:ChangeState(Enum.HumanoidStateType.Jumping)
            end
        end

        if state then

            _G.jumpInputConn = UIS.InputBegan:Connect(function(input, gpe)
                if gpe then return end

                if input.KeyCode == Enum.KeyCode.Space then
                    jump()
                end
            end)

            _G.jumpBtnConn = game:GetService("RunService").RenderStepped:Connect(function()
                if not _G.jumpEnabled then return end

                local gui = game.CoreGui:FindFirstChild("MobileJumpButton")
                if gui then
                    local btn = gui:FindFirstChildWhichIsA("ImageButton", true)
                    if btn and not btn:GetAttribute("Connected") then
                        btn:SetAttribute("Connected", true)
                        btn.MouseButton1Click:Connect(jump)
                    end
                end
            end)

        else

            if _G.jumpInputConn then
                _G.jumpInputConn:Disconnect()
                _G.jumpInputConn = nil
            end

            if _G.jumpBtnConn then
                _G.jumpBtnConn:Disconnect()
                _G.jumpBtnConn = nil
            end

        end

    end
})

