VisualsTab:Toggle({
    Title = "Survivor Tracers",
    Desc = "",
    Value = false,
    Callback = function(state)

        local alive = workspace.PLAYERS.ALIVE
        local player = game.Players.LocalPlayer
        _G.survivorTracer = state
        _G.survivorColor = _G.survivorColor or Color3.fromRGB(0,100,0)

        if state then
            _G.tracerConn = game:GetService("RunService").RenderStepped:Connect(function()
                if not _G.survivorTracer then return end

                for _,v in ipairs(alive:GetChildren()) do
                    if v:IsA("Model") then
                        local root = v:FindFirstChild("HumanoidRootPart")
                        local myRoot = player.Character and player.Character:FindFirstChild("HumanoidRootPart")

                        if root and myRoot then
                            if not v:FindFirstChild("TRACER") then
                                local beam = Instance.new("Beam")
                                beam.Name = "TRACER"

                                local a0 = Instance.new("Attachment", myRoot)
                                local a1 = Instance.new("Attachment", root)

                                beam.Attachment0 = a0
                                beam.Attachment1 = a1
                                beam.Color = ColorSequence.new(_G.survivorColor)
                                beam.Width0 = 0.05
                                beam.Width1 = 0.05
                                beam.Parent = v

                                beam:SetAttribute("A0", a0)
                                beam:SetAttribute("A1", a1)
                            end
                        end
                    end
                end
            end)
        else
            if _G.tracerConn then _G.tracerConn:Disconnect() _G.tracerConn = nil end

            for _,v in ipairs(alive:GetChildren()) do
                local t = v:FindFirstChild("TRACER")
                if t then
                    local a0 = t:GetAttribute("A0")
                    local a1 = t:GetAttribute("A1")
                    if typeof(a0) == "Instance" then a0:Destroy() end
                    if typeof(a1) == "Instance" then a1:Destroy() end
                    t:Destroy()
                end
            end
        end
    end
})

