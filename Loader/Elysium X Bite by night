                            frame.AnchorPoint = Vector2.new(0.5,0.5)
                            frame.Position = UDim2.new(0.5,0,0.5,0)

                        end
                    end
                end

            end)

        else

            _G.dotEnabled = false

            if _G.dotConn then
                _G.dotConn:Disconnect()
                _G.dotConn = nil
            end

        end
    end
})

MovementTab:Toggle({
    Title = "Infinite Stamina",
    Desc = "",
    Flag = "InfStamina",
    Value = false,
    Callback = function(state)
        if state then
            local p = game.Players.LocalPlayer.Character

            game.Players.LocalPlayer.CharacterAdded:Connect(function(ch)
                p = ch
            end)

            local old
            old = hookmetamethod(game, "__namecall", newcclosure(function(self, ...)
                local method = getnamecallmethod()
                local args = {...}

                if not checkcaller() and p and self == p and method == "GetAttribute" and args[1] == "Stamina" then
                    return math.huge
                end

                return old(self, ...)
            end))

            getgenv()._infStaminaHook = old
        else
            if getgenv()._infStaminaHook then
                hookmetamethod(game, "__namecall", getgenv()._infStaminaHook)
                getgenv()._infStaminaHook = nil
            end
        end
    end
})

