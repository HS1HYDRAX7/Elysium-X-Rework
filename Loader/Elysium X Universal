OthersTab:Toggle({
    Title = "Aimbot",
    Value = false,
    Callback = function(enabled)
        local RunService = game:GetService("RunService")
        local Players = game:GetService("Players")
        local LocalPlayer = Players.LocalPlayer
        local Camera = workspace.CurrentCamera

        getgenv().AIM_PART = getgenv().AIM_PART or "Head"
        getgenv().SELECTED_PLAYERS = getgenv().SELECTED_PLAYERS or {}
        getgenv().AIM_CONNECTION = getgenv().AIM_CONNECTION or nil

        if enabled then
            getgenv().AIM_CONNECTION = RunService.RenderStepped:Connect(function()
                if not LocalPlayer.Character
                or not LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
                or #getgenv().SELECTED_PLAYERS == 0 then
                    return
                end

                local closest, closestDist = nil, math.huge
                local myPos = LocalPlayer.Character.HumanoidRootPart.Position

                for _, name in ipairs(getgenv().SELECTED_PLAYERS) do
                    local plr = Players:FindFirstChild(name)
                    if not plr or not plr.Character or not plr.Character:FindFirstChild(getgenv().AIM_PART) then continue end

                    local hum = plr.Character:FindFirstChild("Humanoid")
                    if hum and hum.Health <= 0 then continue end
                    if plr == LocalPlayer then continue end

                    local targetPos = plr.Character[getgenv().AIM_PART].Position
                    local dist = (myPos - targetPos).Magnitude

                    if dist < closestDist then
                        closestDist = dist
                        closest = targetPos
                    end
                end

                if closest then
                    local current = Camera.CFrame
                    local target = CFrame.new(current.Position, closest)
                    local smoothness = 0.12 + math.random(-5, 5) / 100
                    Camera.CFrame = current:Lerp(target, smoothness)
                end
            end)
        else
            if getgenv().AIM_CONNECTION then
                getgenv().AIM_CONNECTION:Disconnect()
                getgenv().AIM_CONNECTION = nil
            end
        end
    end
})

