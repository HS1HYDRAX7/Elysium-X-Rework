WaypointsTab:Button({
    Title = "Play Waypoints",
    Locked = false,
    Callback = function()

        local Players = game:GetService("Players")
        local PathfindingService = game:GetService("PathfindingService")

        local player = Players.LocalPlayer
        local character = player.Character or player.CharacterAdded:Wait()
        local humanoid = character:WaitForChild("Humanoid")
        local root = character:WaitForChild("HumanoidRootPart")

        _G.ELYSIUM_WAYPOINTS = _G.ELYSIUM_WAYPOINTS or {}
        local waypoints = _G.ELYSIUM_WAYPOINTS

        if #waypoints == 0 then
            return
        end

        for i, data in ipairs(waypoints) do
            if data and data.Position then
                local path = PathfindingService:CreatePath()
                path:ComputeAsync(root.Position, data.Position)

                if path.Status == Enum.PathStatus.Success then
                    local points = path:GetWaypoints()
                    for _, point in ipairs(points) do
                        humanoid:MoveTo(point.Position)
                        humanoid.MoveToFinished:Wait()
                    end
                end
            end
        end

    end
})

WaypointsTab:Button({
    Title = "Add Waypoint",
    Locked = false,
    Callback = function()

        local Players = game:GetService("Players")
        local player = Players.LocalPlayer
        local character = player.Character or player.CharacterAdded:Wait()
        local root = character:WaitForChild("HumanoidRootPart")

        _G.ELYSIUM_WAYPOINTS = _G.ELYSIUM_WAYPOINTS or {}
        local waypoints = _G.ELYSIUM_WAYPOINTS

        local position = root.Position

        local part = Instance.new("Part")
        part.Anchored = true
        part.CanCollide = false
        part.Transparency = 1
        part.Size = Vector3.new(1,1,1)
        part.Position = position
        part.Name = "ElysiumWaypoint"
        part.Parent = workspace

        local billboard = Instance.new("BillboardGui")
        billboard.Size = UDim2.new(0, 60, 0, 60)
        billboard.AlwaysOnTop = true
        billboard.StudsOffset = Vector3.new(0, 3, 0)
        billboard.Parent = part

        local image = Instance.new("ImageLabel")
        image.Size = UDim2.new(1,0,1,0)
        image.BackgroundTransparency = 1
        image.Parent = billboard

        if #waypoints == 0 then
            image.Image = "rbxassetid://80546885029816"
        else
            image.Image = "rbxassetid://84279202219901"
        end

        table.insert(waypoints, {
            Part = part,
            Position = position
        })

    end
})

WaypointsTab:Button({
    Title = "Remove Waypoint",
    Locked = false,
    Callback = function()

        local Players = game:GetService("Players")
        local player = Players.LocalPlayer
        local character = player.Character or player.CharacterAdded:Wait()
        local root = character:WaitForChild("HumanoidRootPart")

        _G.ELYSIUM_WAYPOINTS = _G.ELYSIUM_WAYPOINTS or {}
        local waypoints = _G.ELYSIUM_WAYPOINTS

        local removeIndex = nil
        local minDistance = 5

        for i, data in ipairs(waypoints) do
            if data and data.Part then
                local distance = (root.Position - data.Part.Position).Magnitude
                if distance <= minDistance then
                    removeIndex = i
                    break
                end
            end
        end

        if removeIndex then
            local data = waypoints[removeIndex]
            if data.Part then
                data.Part:Destroy()
            end
            table.remove(waypoints, removeIndex)

            if waypoints[1] and waypoints[1].Part then
                local gui = waypoints[1].Part:FindFirstChildOfClass("BillboardGui")
                if gui then
                    local img = gui:FindFirstChildOfClass("ImageLabel")
                    if img then
                        img.Image = "rbxassetid://80546885029816"
                    end
                end
            end
        end

    end
})

