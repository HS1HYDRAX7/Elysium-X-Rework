MiscTab:Dropdown({
    Title = "Musics",
    Values = (function()

        local file = "musicz.json"
        if not isfile(file) then
            writefile(file, "[]")
        end

        local data = game:GetService("HttpService"):JSONDecode(readfile(file))
        table.sort(data, function(a,b) return (a.Index or 0) < (b.Index or 0) end)

        local names = {}
        for _,v in ipairs(data) do
            table.insert(names, "["..v.Index.."] "..v.Name)
        end

        _G._musicData = data
        return names

    end)(),
    Callback = function(selected)

        _G._selectedMusic = selected

        if not _G._musicData then return end

        for _,v in ipairs(_G._musicData) do
            local label = "["..v.Index.."] "..v.Name

            if label == selected then

                if _G._sound then
                    _G._sound:Stop()
                    _G._sound:Destroy()
                end

                local sound = Instance.new("Sound")
                sound.SoundId = "rbxassetid://" .. v.ID
                sound.Volume = 1
                sound.Parent = game:GetService("SoundService")

                _G._sound = sound
                _G._selectedIndex = v.Index
                break
            end
        end

    end
})

