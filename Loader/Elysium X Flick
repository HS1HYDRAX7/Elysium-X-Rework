VisualsTab:Toggle({
    Title = "Players ESP",
    Desc = "",
    Value = false,
    Callback = function(state)

        local Players = game:GetService("Players")

        _G._espEnabled = state
        _G._espColor = _G._espColor or Color3.fromRGB(255,255,255)

        local function apply(char)
            if not char then return end

            local h = char:FindFirstChild("ESP_HIGHLIGHT")
            if h then h:Destroy() end

            if _G._espEnabled then
                local highlight = Instance.new("Highlight")
                highlight.Name = "ESP_HIGHLIGHT"
                highlight.FillColor = _G._espColor
                highlight.OutlineColor = _G._espColor
                highlight.Adornee = char
                highlight.Parent = char
            end
        end

        local function setup(plr)
            if plr == Players.LocalPlayer then return end

            if plr.Character then
                apply(plr.Character)
            end

            plr.CharacterAdded:Connect(function(char)
                task.wait()
                apply(char)
            end)
        end

        if state then

            for _,plr in ipairs(Players:GetPlayers()) do
                setup(plr)
            end

            _G._espJoin = Players.PlayerAdded:Connect(function(plr)
                setup(plr)
            end)

        else

            if _G._espJoin then
                _G._espJoin:Disconnect()
                _G._espJoin = nil
            end

            for _,plr in ipairs(Players:GetPlayers()) do
                if plr.Character then
                    local h = plr.Character:FindFirstChild("ESP_HIGHLIGHT")
                    if h then h:Destroy() end
                end
            end

        end

    end
})

