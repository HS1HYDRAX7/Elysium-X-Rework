MPS:Button({
    Title = "Save Music",
    Callback = function()

        local HttpService = game:GetService("HttpService")
        local file = "musicz.json"

        if not isfile(file) then
            writefile(file, "[]")
        end

        local data = HttpService:JSONDecode(readfile(file))

        if _G._musicIndex and _G._newMusicName and _G._newMusicID then

            local replaced = false

            for i,v in ipairs(data) do
                if v.Index == _G._musicIndex then
                    data[i] = {
                        Index = _G._musicIndex,
                        Name = _G._newMusicName,
                        ID = _G._newMusicID
                    }
                    replaced = true
                    break
                end
            end

            if not replaced then
                table.insert(data, {
                    Index = _G._musicIndex,
                    Name = _G._newMusicName,
                    ID = _G._newMusicID
                })
            end

            table.sort(data, function(a,b) return a.Index < b.Index end)

            writefile(file, HttpService:JSONEncode(data))
        end

    end
})

MPS:Button({
    Title = "Delete Music",
    Callback = function()

        local HttpService = game:GetService("HttpService")
        local file = "musicz.json"

        if not isfile(file) then return end

        local data = HttpService:JSONDecode(readfile(file))
        local newData = {}

        for _,v in ipairs(data) do
            if v.Index ~= _G._selectedIndex then
                table.insert(newData, v)
            end
        end

        writefile(file, HttpService:JSONEncode(newData))

        if _G._sound then
            _G._sound:Stop()
            _G._sound:Destroy()
            _G._sound = nil
        end

    end
})

