PlayerTab:Toggle({
    Title = "Inf stamina",
    Desc = "",
    Value = false,
    Callback = (function()
        local Players = game:GetService("Players")
        local RunService = game:GetService("RunService")
        local player = Players.LocalPlayer

        local connection = nil
        local enabled = false

        local function setupCharacter(char)
            if not char then return end

            if char:GetAttribute("Running") == nil then
                char:SetAttribute("Running", true)
            end

            if char:GetAttribute("Stamina") == nil then
                char:SetAttribute("Stamina", 100)
            end
        end

        local function start()
            if enabled then return end
            enabled = true

            if player.Character then
                setupCharacter(player.Character)
            end

            connection = RunService.Heartbeat:Connect(function()
                local char = player.Character
                if not char then return end

                if char:GetAttribute("Stamina") ~= math.huge then
                    char:SetAttribute("Stamina", math.huge)
                end

                if char:GetAttribute("Running") ~= true then
                    char:SetAttribute("Running", true)
                end
            end)
        end

        local function stop()
            if not enabled then return end
            enabled = false

            if connection then
                connection:Disconnect()
                connection = nil
            end

            local char = player.Character
            if char then
                char:SetAttribute("Stamina", 100)
                char:SetAttribute("Running", false)
            end
        end

        player.CharacterAdded:Connect(function(char)
            if enabled then
                setupCharacter(char)
            end
        end)

        return function(state)
            if state then
                start()
            else
                stop()
            end
        end
    end)()
})

VisualsTab:Toggle({
    Title = "Survivors ESP",
    Desc = "",
    Value = false,
    Callback = function(state)
        if not getgenv()._SurvivorsESP then
            getgenv()._SurvivorsESP = {
                Enabled = false,
                Color = Color3.fromRGB(0,100,0),
                Connections = {}
            }

            local function apply(obj)
                if not obj:IsA("Model") then return end
                local h = obj:FindFirstChild("ESPHighlight")

                if getgenv()._SurvivorsESP.Enabled then
                    if not h then
                        h = Instance.new("Highlight")
                        h.Name = "ESPHighlight"
                        h.FillTransparency = 0.5
                        h.OutlineTransparency = 0
                        h.Parent = obj
                    end
                    h.FillColor = getgenv()._SurvivorsESP.Color
                    h.OutlineColor = getgenv()._SurvivorsESP.Color
                else
                    if h then h:Destroy() end
                end
            end

            local folder = workspace:FindFirstChild("PLAYERS") and workspace.PLAYERS:FindFirstChild("ALIVE")

            if folder then
                for _, v in ipairs(folder:GetChildren()) do
                    apply(v)
                end

                table.insert(getgenv()._SurvivorsESP.Connections, folder.ChildAdded:Connect(apply))
            end
        end

        getgenv()._SurvivorsESP.Enabled = state

        local folder = workspace:FindFirstChild("PLAYERS") and workspace.PLAYERS:FindFirstChild("ALIVE")
        if folder then
            for _, v in ipairs(folder:GetChildren()) do
                local h = v:FindFirstChild("ESPHighlight")
                if not state and h then
                    h:Destroy()
                elseif state then
                    local h2 = h or Instance.new("Highlight")
                    h2.Name = "ESPHighlight"
                    h2.FillTransparency = 0.5
                    h2.OutlineTransparency = 0
                    h2.FillColor = getgenv()._SurvivorsESP.Color
                    h2.OutlineColor = getgenv()._SurvivorsESP.Color
                    h2.Parent = v
                end
            end
        end
    end
})

