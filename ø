local BlockSec = ElysiumSec:Section({
    Title = "Auto block",
})

BlockSec:Toggle({
    Title = "Auto block",
    Desc = "",
    Value = false,
    Callback = function(state)
        elysiumplusFeature(function()
            _G.AutoBlockEnabled = state
            _G.AutoBlockRange = _G.AutoBlockRange or 10

            if state == true then
                _G.AutoBlockUnhook = false
                _G.AutoBlockConnections = _G.AutoBlockConnections or {}

                local AB_UA = game:GetService("ReplicatedStorage")
                    :WaitForChild("Events")
                    :WaitForChild("RemoteFunctions")
                    :WaitForChild("UseAbility")

                local function TryBlock(killerHRP)
                    if not _G.AutoBlockEnabled then return end
                    local localChar = game.Players.LocalPlayer.Character
                    if not localChar then return end
                    local hrp = localChar:FindFirstChild("HumanoidRootPart")
                    if not hrp then return end

                    local mag = (killerHRP.Position - hrp.Position).Magnitude
                    if mag >= tonumber(_G.AutoBlockRange) then return end

                    local unit = ((hrp.Position - killerHRP.Position) * Vector3.new(1,0,1)).Unit
                    local lookvector = killerHRP.CFrame.LookVector * Vector3.new(1,0,1)
                    if lookvector:Dot(unit) <= 0.75 then return end

                    AB_UA:InvokeServer("Block")
                end

                local function HookOnto(chr)
                    local timeout = 0
                    while not chr:FindFirstChild("HumanoidRootPart") and timeout < 5 do
                        task.wait(0.1)
                        timeout += 0.1
                    end

                    local hrp = chr:FindFirstChild("HumanoidRootPart")
                    if not hrp then return end

                    local chrn = chr.Name
                    if not workspace.GameAssets.Teams.Killer:FindFirstChild(chrn) then return end

                    local connections = {}
                    _G.AutoBlockConnections[chrn] = connections

                    local swing = hrp:FindFirstChild("Swing")
                    if not swing then
                        local t2 = 0
                        while not hrp:FindFirstChild("Swing") and t2 < 3 do
                            task.wait(0.1)
                            t2 += 0.1
                        end
                        swing = hrp:FindFirstChild("Swing")
                    end

                    if swing and swing:IsA("Sound") then
                        local c1 = swing.Played:Connect(function()
                            TryBlock(hrp)
                        end)
                        table.insert(connections, c1)

                        local wasPlaying = false
                        local loopConn = game:GetService("RunService").Heartbeat:Connect(function()
                            if not _G.AutoBlockEnabled or _G.AutoBlockUnhook then return end
                            local isPlaying = swing.IsPlaying
                            if isPlaying and not wasPlaying then
                                TryBlock(hrp)
                            end
                            wasPlaying = isPlaying
                        end)
                        table.insert(connections, loopConn)
                    end

                    repeat task.wait(0.2) until
                        not workspace.GameAssets.Teams.Killer:FindFirstChild(chrn)
                        or _G.AutoBlockUnhook == true

                    for _, conn in next, connections do
                        pcall(function() conn:Disconnect() end)
                    end
                    _G.AutoBlockConnections[chrn] = nil
                end

                for _, v in next, workspace.GameAssets.Teams.Killer:GetChildren() do
                    task.spawn(HookOnto, v)
                end

                local killerAddedConn = workspace.GameAssets.Teams.Killer.ChildAdded:Connect(function(v)
                    if _G.AutoBlockEnabled and not _G.AutoBlockUnhook then
                        task.spawn(HookOnto, v)
                    end
                end)
                _G.AutoBlockKillerAddedConn = killerAddedConn

            else
                _G.AutoBlockUnhook = true

                if _G.AutoBlockKillerAddedConn then
                    _G.AutoBlockKillerAddedConn:Disconnect()
                    _G.AutoBlockKillerAddedConn = nil
                end

                if _G.AutoBlockConnections then
                    for _, conns in next, _G.AutoBlockConnections do
                        for _, c in next, conns do
                            pcall(function() c:Disconnect() end)
                        end
                    end
                    _G.AutoBlockConnections = {}
                end

                task.wait(0.1)
                _G.AutoBlockUnhook = false
            end
        end)
    end
})

