task.spawn(function()
    while true do
        local NewMusics = GetMusics()

        if not TablesEqual(CachedMusics, NewMusics) then
            CachedMusics = NewMusics

            MusicDropdown:Refresh(NewMusics)
        end

        task.wait(2)
    end
end)

